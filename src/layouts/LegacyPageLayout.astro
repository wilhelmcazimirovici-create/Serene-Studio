---
import { property, SITE_URL, absoluteUrl } from "@/data/site";

type LegacyLocale = "es" | "ru";

type Props = {
  locale: LegacyLocale;
  path: string;
  title: string;
  description: string;
  hreflangRo: string;
  hreflangEn: string;
  hreflangEs?: string;
  hreflangRu?: string;
  bookingReferer: string;
};

const {
  locale,
  path,
  title,
  description,
  hreflangRo,
  hreflangEn,
  hreflangEs,
  hreflangRu,
  bookingReferer
} = Astro.props;

const canonical = absoluteUrl(path);
const socialImage = `${SITE_URL}/images/og-serene-studio.webp`;

const dictionaries = {
  es: {
    skipContent: "Saltar al contenido",
    bookCta: "Reservar online",
    legacyNotice:
      "Versión completa en español próximamente. Para todos los detalles, consulta también el sitio en inglés.",
    seeEnglish: "Ver el sitio en inglés",
    contactHeading: "Contacto",
    addressLabel: "Dirección"
  },
  ru: {
    skipContent: "Перейти к содержанию",
    bookCta: "Забронировать онлайн",
    legacyNotice:
      "Полная версия на русском языке появится в ближайшее время. Все подробности также доступны на английской версии сайта.",
    seeEnglish: "Посмотреть сайт на английском",
    contactHeading: "Контакты",
    addressLabel: "Адрес"
  }
};

const l = dictionaries[locale];
const lang = locale;

const bookingHref = `https://beds24.com/booking.php?propid=${property.bookingPropertyId}&referer=${bookingReferer}`;

const baseSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: "Serene Studio",
    url: SITE_URL
  },
  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "@id": `${SITE_URL}/#lodging`,
    name: "Serene Studio",
    url: SITE_URL,
    telephone: property.phone,
    email: property.email,
    address: {
      "@type": "PostalAddress",
      streetAddress: property.streetAddress,
      addressLocality: property.locality,
      addressRegion: property.region,
      postalCode: property.postalCode,
      addressCountry: property.country
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: property.latitude,
      longitude: property.longitude
    },
    checkinTime: property.checkin,
    checkoutTime: property.checkout
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonical}#webpage`,
    url: canonical,
    name: title,
    description,
    inLanguage: lang,
    isPartOf: { "@id": `${SITE_URL}/#website` },
    about: { "@id": `${SITE_URL}/#lodging` }
  }
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ro" href={absoluteUrl(hreflangRo)} />
    <link rel="alternate" hreflang="en" href={absoluteUrl(hreflangEn)} />
    {hreflangEs && <link rel="alternate" hreflang="es" href={absoluteUrl(hreflangEs)} />}
    {hreflangRu && <link rel="alternate" hreflang="ru" href={absoluteUrl(hreflangRu)} />}
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(hreflangRo)} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={socialImage} />
    <meta name="theme-color" content="#f97316" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": baseSchema })}></script>
    <style>
      :root {
        --legacy-bg: #faf6ef;
        --legacy-surface: #ffffff;
        --legacy-text: #2b2620;
        --legacy-muted: #6b6358;
        --legacy-accent: #c66a4a;
        --legacy-accent-hover: #b15a3d;
        --legacy-sage: #9aab8e;
        --legacy-border: rgba(43, 38, 32, 0.08);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        background: var(--legacy-bg);
        color: var(--legacy-text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      .container { max-width: 960px; margin: 0 auto; padding: 0 1.25rem; }
      a { color: var(--legacy-accent); }
      a:hover { color: var(--legacy-accent-hover); }
      .skip-link { position: absolute; left: -9999px; top: 0; }
      .skip-link:focus { left: 1rem; top: 1rem; background: var(--legacy-surface); padding: 0.5rem 0.75rem; z-index: 10; }
      .legacy-header {
        background: var(--legacy-surface);
        border-bottom: 1px solid var(--legacy-border);
        padding: 1rem 0;
      }
      .legacy-header .container {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .legacy-brand {
        font-weight: 600;
        font-size: 1.05rem;
        text-decoration: none;
        color: var(--legacy-text);
      }
      .legacy-langs {
        display: flex;
        gap: 0.75rem;
        margin-left: auto;
        font-size: 0.9rem;
      }
      .legacy-langs a {
        color: var(--legacy-muted);
        text-decoration: none;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
      }
      .legacy-langs a:hover { background: var(--legacy-border); color: var(--legacy-text); }
      .legacy-langs a[aria-current="page"] { color: var(--legacy-text); font-weight: 600; }
      .legacy-cta {
        background: var(--legacy-accent);
        color: #fff;
        padding: 0.55rem 1rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.95rem;
      }
      .legacy-cta:hover { background: var(--legacy-accent-hover); color: #fff; }
      .legacy-main { padding: 2.5rem 0 4rem; }
      .legacy-main h1 {
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        margin: 0 0 1rem;
        line-height: 1.2;
      }
      .legacy-main h2 {
        font-size: clamp(1.2rem, 2.5vw, 1.5rem);
        margin: 2.25rem 0 0.75rem;
      }
      .legacy-main p {
        margin: 0 0 1rem;
        max-width: 65ch;
      }
      .legacy-main ul {
        max-width: 65ch;
        padding-left: 1.25rem;
      }
      .legacy-main li { margin-bottom: 0.5rem; }
      .legacy-notice {
        background: rgba(154, 171, 142, 0.15);
        border-left: 3px solid var(--legacy-sage);
        padding: 1rem 1.25rem;
        margin: 1.5rem 0 2rem;
        border-radius: 0 8px 8px 0;
        font-size: 0.95rem;
      }
      .legacy-notice a { color: var(--legacy-text); }
      .legacy-final-cta {
        margin-top: 2.5rem;
        padding: 1.5rem;
        background: var(--legacy-surface);
        border-radius: 12px;
        border: 1px solid var(--legacy-border);
      }
      .legacy-final-cta a {
        display: inline-block;
        margin-top: 0.75rem;
      }
      .legacy-footer {
        background: var(--legacy-surface);
        border-top: 1px solid var(--legacy-border);
        padding: 2rem 0;
        font-size: 0.9rem;
        color: var(--legacy-muted);
      }
      .legacy-footer a { color: var(--legacy-muted); }
      .legacy-footer p { margin: 0 0 0.5rem; }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#content">{l.skipContent}</a>
    <header class="legacy-header">
      <div class="container">
        <a class="legacy-brand" href={path}>Serene Studio</a>
        <nav class="legacy-langs" aria-label="Languages">
          <a href={hreflangRo}>RO</a>
          <a href={hreflangEn}>EN</a>
          {hreflangEs && <a href={hreflangEs} aria-current={locale === "es" ? "page" : undefined}>ES</a>}
          {hreflangRu && <a href={hreflangRu} aria-current={locale === "ru" ? "page" : undefined}>RU</a>}
        </nav>
        <a
          class="legacy-cta"
          href={bookingHref}
          data-booking-link
          data-referer={bookingReferer}
          rel="nofollow sponsored noopener"
        >{l.bookCta}</a>
      </div>
    </header>
    <main id="content" class="legacy-main">
      <div class="container">
        <slot />
        <div class="legacy-notice">
          {l.legacyNotice} <a href={hreflangEn}>{l.seeEnglish}</a>.
        </div>
      </div>
    </main>
    <footer class="legacy-footer">
      <div class="container">
        <p><strong>{property.fullName}</strong></p>
        <p>{l.addressLabel}: {property.address}</p>
        <p>
          <a href={`tel:${property.phone.replace(/\s/g, "")}`}>{property.phone}</a> ·
          <a href={`mailto:${property.email}`}>{property.email}</a>
        </p>
      </div>
    </footer>
  </body>
</html>
