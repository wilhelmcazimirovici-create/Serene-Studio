---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BookingCta from "@/components/BookingCta.astro";
import { absoluteUrl, bookingUrl, labels, property, SITE_URL, type Locale } from "@/data/site";
import "@/styles/global.css";

type Alternate = {
  hreflang: string;
  href: string;
};

type Props = {
  locale: Locale;
  path: string;
  translationPath: string;
  title: string;
  description: string;
  keyword?: string;
  schema?: Record<string, unknown>[];
  alternates?: Alternate[];
};

const { locale, path, translationPath, title, description, keyword, schema = [], alternates = [] } = Astro.props;
const l = labels[locale];
const canonical = absoluteUrl(path);
const lang = locale === "ro" ? "ro" : "en";

const baseSchema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: "Serene Studio",
    url: SITE_URL,
    inLanguage: lang,
    potentialAction: {
      "@type": "ReserveAction",
      target: bookingUrl(`website_${locale}_schema`, locale),
      name: l.reserve
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "@id": `${SITE_URL}/#lodging`,
    name: "Serene Studio",
    url: SITE_URL,
    telephone: property.phone,
    email: property.email,
    address: {
      "@type": "PostalAddress",
      streetAddress: property.streetAddress,
      addressLocality: property.locality,
      addressRegion: property.region,
      postalCode: property.postalCode,
      addressCountry: property.country
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: property.latitude,
      longitude: property.longitude
    },
    checkinTime: property.checkin,
    checkoutTime: property.checkout,
    petsAllowed: false,
    smokingAllowed: false,
    amenityFeature: [
      "Self check-in",
      "Fast Wi-Fi",
      "Kitchenette",
      "Terrace",
      "Free street parking",
      "Air conditioning",
      "Central heating"
    ].map((name) => ({ "@type": "LocationFeatureSpecification", name, value: true })),
    potentialAction: {
      "@type": "ReserveAction",
      target: bookingUrl(`website_${locale}_lodging_schema`, locale),
      name: l.reserve
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${canonical}#webpage`,
    url: canonical,
    name: title,
    description,
    inLanguage: lang,
    isPartOf: { "@id": `${SITE_URL}/#website` },
    about: { "@id": `${SITE_URL}/#lodging` }
  }
];

const graph = [...baseSchema, ...schema];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keyword && <meta name="keywords" content={keyword} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ro" href={absoluteUrl(locale === "ro" ? path : translationPath)} />
    <link rel="alternate" hreflang="en" href={absoluteUrl(locale === "en" ? path : translationPath)} />
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(locale === "ro" ? path : translationPath)} />
    {alternates.map((alternate) => <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />)}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE_URL}/images/og-serene-studio.webp`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f97316" data-theme-color />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
    <script is:inline>
      (function () {
        var key = "serene-theme";
        var theme = "light";
        try {
          var stored = localStorage.getItem(key);
          if (stored === "dark" || stored === "light") theme = stored;
          else if (window.matchMedia("(prefers-color-scheme: dark)").matches) theme = "dark";
        } catch (e) {}
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": graph })}></script>
  </head>
  <body>
    <!-- One-time SVG filter for liquid-glass refraction lenses -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter id="liquid-refract" x="-20%" y="-20%" width="140%" height="140%">
          <feTurbulence type="fractalNoise" baseFrequency="0.012 0.018" numOctaves="2" seed="3" />
          <feGaussianBlur stdDeviation="0.6" />
          <feDisplacementMap in="SourceGraphic" scale="14" xChannelSelector="R" yChannelSelector="G" />
        </filter>
      </defs>
    </svg>

    <a class="skip-link" href="#content">{l.content}</a>
    <Header locale={locale} currentPath={path} translationPath={translationPath} />
    <main id="content" class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} translationPath={translationPath} />
    <div class="mobile-booking-bar" aria-label={l.reserve}>
      <BookingCta locale={locale} referer={`website_${locale}_mobile_sticky`} label={l.reserve} />
    </div>

    <script>
      (() => {
        const storageKey = "serene-theme";
        const lightColor = "#f97316";
        const darkColor = "#0f0d0a";
        const root = document.documentElement;
        const buttons = document.querySelectorAll<HTMLButtonElement>("[data-theme-toggle]");

        const setMetaThemeColor = (theme: string) => {
          document
            .querySelector('meta[data-theme-color]')
            ?.setAttribute("content", theme === "dark" ? darkColor : lightColor);
        };

        const setTheme = (theme: string, persist = false) => {
          theme = theme === "dark" ? "dark" : "light";
          root.dataset.theme = theme;
          root.style.colorScheme = theme;
          setMetaThemeColor(theme);
          buttons.forEach((button) => {
            const nextIsDark = theme !== "dark";
            const label = nextIsDark
              ? button.getAttribute("data-theme-label-dark")
              : button.getAttribute("data-theme-label-light");
            button.setAttribute("aria-label", label || "Change theme");
            button.setAttribute("title", label || "Change theme");
            button.setAttribute("aria-pressed", String(theme === "dark"));
          });
          if (persist) {
            try {
              localStorage.setItem(storageKey, theme);
            } catch {
              // localStorage can be unavailable in hardened browsers
            }
          }
          window.dispatchEvent(new CustomEvent("serene_theme_change", { detail: { theme } }));
        };

        setTheme(root.dataset.theme || "light");
        buttons.forEach((button) => {
          button.addEventListener("click", () => {
            setTheme(root.dataset.theme === "dark" ? "light" : "dark", true);
          });
        });

        const media = window.matchMedia("(prefers-color-scheme: dark)");
        media.addEventListener("change", (event) => {
          let saved: string | null = null;
          try {
            saved = localStorage.getItem(storageKey);
          } catch {}
          if (saved !== "dark" && saved !== "light") {
            setTheme(event.matches ? "dark" : "light");
          }
        });

        // Beds24 booking-link analytics dispatch
        document.addEventListener("click", (event) => {
          const target = event.target as Element | null;
          const link = target?.closest?.("[data-booking-link]");
          if (!link) return;
          window.dispatchEvent(
            new CustomEvent("book_click", {
              detail: {
                referer: link.getAttribute("data-referer"),
                href: link.getAttribute("href")
              }
            })
          );
        });
      })();
    </script>
  </body>
</html>