---
import BookingCta from "./BookingCta.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { labels, nav, type Locale } from "@/data/site";

type Props = {
  locale: Locale;
  currentPath: string;
  translationPath: string;
};

const { locale, currentPath, translationPath } = Astro.props;
const l = labels[locale];
const otherLocale: Locale = locale === "ro" ? "en" : "ro";
const otherHref = translationPath;
const otherLabel = otherLocale === "ro" ? "Romana" : "English";
const langWidgetLabel = locale === "ro" ? "Limba" : "Language";
---

<header class="sticky top-0 z-40 glass-nav">
  <nav class="container-max flex h-16 items-center justify-between gap-4" aria-label="Primary">
    <a
      href={locale === "ro" ? "/" : "/en/"}
      class="inline-flex items-center gap-2 text-ink-900 hover:opacity-80 transition no-underline"
      aria-label="Serene Studio"
    >
      <span
        aria-hidden="true"
        class="grid place-items-center w-9 h-9 rounded-2xl text-white font-bold text-base"
        style="background: linear-gradient(140deg, var(--brand) 0%, var(--brand-2) 100%); box-shadow: 0 6px 14px rgba(249, 115, 22, 0.32);"
      >S</span>
      <span class="font-bold tracking-tight text-[0.98rem] sm:text-[1.02rem]">Serene Studio</span>
    </a>

    <ul class="hidden md:flex items-center gap-0.5 text-sm list-none m-0 p-0">
      {nav[locale].map((item) => (
        <li class="m-0 p-0">
          <a
            href={item.href}
            class={`px-3.5 py-2 rounded-full font-medium transition no-underline ${
              currentPath === item.href
                ? "text-brand-700 bg-white/55 ring-1 ring-white/60 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)]"
                : "text-ink-700 hover:text-ink-900 hover:bg-white/35"
            }`}
            aria-current={currentPath === item.href ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <ThemeToggle locale={locale} />

      <details class="relative" data-lang-menu>
        <summary
          class="list-none cursor-pointer rounded-full px-3 py-2 text-sm font-medium text-ink-700 hover:bg-white/40 transition select-none"
          aria-label={langWidgetLabel}
        >
          <span class="inline-flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20" />
            </svg>
            <span class="uppercase">{locale}</span>
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </summary>
        <ul class="lang-grid absolute right-0 mt-2 w-44 glass-strong rounded-2xl p-2 text-sm z-50 grid grid-cols-1 gap-1 list-none">
          <li class="m-0 p-0">
            <a
              href={locale === "ro" ? currentPath : otherHref}
              hreflang="ro"
              aria-current={locale === "ro" ? "page" : undefined}
              class={`block w-full text-center rounded-xl px-2 py-2 transition no-underline ${
                locale === "ro"
                  ? "text-brand-700 font-semibold bg-white/55 ring-1 ring-white/60"
                  : "text-ink-700 bg-white/25 hover:bg-white/55"
              }`}
            >Romana</a>
          </li>
          <li class="m-0 p-0">
            <a
              href={locale === "en" ? currentPath : otherHref}
              hreflang="en"
              aria-current={locale === "en" ? "page" : undefined}
              class={`block w-full text-center rounded-xl px-2 py-2 transition no-underline ${
                locale === "en"
                  ? "text-brand-700 font-semibold bg-white/55 ring-1 ring-white/60"
                  : "text-ink-700 bg-white/25 hover:bg-white/55"
              }`}
            >English</a>
          </li>
        </ul>
      </details>

      <BookingCta locale={locale} referer={`website_${locale}_header`} label={l.reserve} class="hidden sm:inline-flex text-sm py-2.5 px-5" />

      <button
        type="button"
        class="md:hidden rounded-full p-2 hover:bg-white/40 transition"
        aria-label={l.menu}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-mobile-toggle
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="md:hidden hidden glass border-t border-white/40" data-mobile-panel>
    <ul class="container-max py-3 grid gap-1 text-sm list-none m-0">
      {nav[locale].map((item) => (
        <li class="m-0 p-0">
          <a
            href={item.href}
            class={`block rounded-xl px-3 py-2.5 font-medium transition no-underline ${
              currentPath === item.href ? "text-brand-700 bg-white/55" : "text-ink-700 hover:bg-white/40"
            }`}
            aria-current={currentPath === item.href ? "page" : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2 m-0 p-0">
        <BookingCta locale={locale} referer={`website_${locale}_header_mobile`} label={l.reserve} class="w-full justify-center text-sm py-3" />
      </li>
    </ul>
  </div>
</header>

<style>
  .lang-grid,
  .lang-grid li { list-style: none !important; }
  .lang-grid li::marker { content: none !important; }
  header a { text-decoration: none; }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const panel = document.querySelector<HTMLElement>("[data-mobile-panel]");
  toggle?.addEventListener("click", () => {
    const open = !panel?.classList.contains("hidden");
    panel?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!open));
    document.body.classList.toggle("menu-open", !open);
  });
  document.addEventListener("click", (event) => {
    document.querySelectorAll<HTMLDetailsElement>("details[data-lang-menu]").forEach((details) => {
      if (!details.contains(event.target as Node)) details.removeAttribute("open");
    });
  });
</script>