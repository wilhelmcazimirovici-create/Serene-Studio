---
import { bookingUrl, labels, type Locale } from "@/data/site";

type Props = {
  locale: Locale;
  referer: string;
  label?: string;
  variant?: "primary" | "secondary";
  class?: string;
};

const { locale, referer, label, variant = "primary", class: className = "" } = Astro.props;
const text = label ?? labels[locale].checkAvailability;
const cls = variant === "secondary" ? "btn-liquid-dark" : "btn-liquid-primary";
---

<a
  class={`${cls} ${className}`}
  href={bookingUrl(referer, locale)}
  data-booking-link
  data-referer={referer}
  rel="nofollow sponsored noopener"
>
  {text}
</a>