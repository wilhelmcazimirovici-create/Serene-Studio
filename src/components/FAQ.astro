---
import type { Faq } from "@/data/types";

type Props = {
  items: Faq[];
};

const { items } = Astro.props;
---

<div class="faq-list">
  {items.map((item, index) => (
    <details class="faq-item" open={index === 0}>
      <summary class="faq-summary">{item.q}</summary>
      <p class="faq-answer">{item.a}</p>
    </details>
  ))}
</div>
