---
type Props = {
  class?: string;
  locale?: "ro" | "en";
};

const { class: className = "", locale = "ro" } = Astro.props;
const labelDark = locale === "ro" ? "Activează tema întunecată" : "Switch to dark theme";
const labelLight = locale === "ro" ? "Activează tema luminoasă" : "Switch to light theme";
---

<button
  type="button"
  class={`theme-toggle ${className}`}
  data-theme-toggle
  data-theme-label-dark={labelDark}
  data-theme-label-light={labelLight}
  aria-label={labelDark}
  aria-pressed="false"
>
  <svg
    class="theme-toggle__icon theme-toggle__icon--sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg
    class="theme-toggle__icon theme-toggle__icon--moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
</button>