---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCardImage from "@/components/BlogCardImage.astro";
import BookingCta from "@/components/BookingCta.astro";
import { getBlogPosts } from "@/data/blog";
import { getBlogCardVisual } from "@/data/blog-card-visuals";
import { absoluteUrl, property, SITE_URL } from "@/data/site";

const posts = getBlogPosts("ro");
const path = "/blog/";
const title = "Blog Serene Studio - ghiduri cazare București";
const description = "Articole practice despre cazare lângă Piața Muncii, Arena Națională, spitale, Parcul IOR și Sector 2 București.";
const itemListElement = posts.map((post, index) => {
  const visual = getBlogCardVisual(post);

  return {
    "@type": "ListItem",
    position: index + 1,
    url: absoluteUrl(`/blog/${post.slug}/`),
    name: post.title,
    description: post.description,
    image: `${SITE_URL}/images/${visual.base}.webp`
  };
});
const schema = [
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Acasă", item: absoluteUrl("/") },
      { "@type": "ListItem", position: 2, name: "Blog", item: absoluteUrl(path) }
    ]
  },
  {
    "@type": "Blog",
    "@id": `${absoluteUrl(path)}#blog`,
    url: absoluteUrl(path),
    name: title,
    description,
    inLanguage: "ro",
    publisher: { "@type": "Organization", name: property.fullName },
    about: { "@id": `${SITE_URL}/#lodging` },
    blogPost: posts.map((post) => ({
      "@type": "BlogPosting",
      headline: post.title,
      url: absoluteUrl(`/blog/${post.slug}/`),
      datePublished: post.date,
      dateModified: post.date
    }))
  },
  {
    "@type": "ItemList",
    "@id": `${absoluteUrl(path)}#blog-list`,
    itemListElement
  }
];
---

<BaseLayout locale="ro" path={path} translationPath="/en/blog/" title={title} description={description} keyword="blog cazare Bucuresti" schema={schema}>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">SEO local · Piața Muncii · Sector 2</p>
      <h1>Blog Serene Studio</h1>
      <p class="hero-lead">{description}</p>
      <div class="hero-actions">
        <BookingCta locale="ro" referer="website_blog_index_hero" label="Verifică disponibilitatea" />
      </div>
    </div>
  </section>
  <section class="band alt">
    <div class="container cards-grid blog-cards-grid">
      {posts.map((post) => {
        const href = `/blog/${post.slug}/`;
        const visual = getBlogCardVisual(post);

        return (
        <article class="blog-card-shell">
          <a class="blog-card" href={href} aria-label={`Citește articolul: ${post.title}`}>
            <span class="blog-card-media">
              <BlogCardImage visual={visual} locale="ro" class="blog-card-image" />
              <span class="blog-card-label">{visual.label.ro}</span>
            </span>
            <span class="blog-card-body">
              <span class="blog-card-meta"><time datetime={post.date}>Actualizat {post.date}</time></span>
              <h2>{post.title}</h2>
              <p>{post.description}</p>
              <span class="blog-card-cta" aria-hidden="true">
                Citește articolul
                <svg viewBox="0 0 24 24" focusable="false"><path d="M5 12h14m0 0-6-6m6 6-6 6" /></svg>
              </span>
            </span>
          </a>
        </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
