---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AirportTrainPlanner from "@/components/AirportTrainPlanner.astro";
import BookingCta from "@/components/BookingCta.astro";
import FAQ from "@/components/FAQ.astro";
import Lightbox from "@/components/Lightbox.astro";
import ResponsiveImage from "@/components/ResponsiveImage.astro";
import SectionVideo from "@/components/SectionVideo.astro";
import { blogPosts, getBlogPosts } from "@/data/blog";
import { BLOG_CARD_IMAGE_HEIGHT, BLOG_CARD_IMAGE_WIDTH, getBlogCardVisual } from "@/data/blog-card-visuals";
import { absoluteUrl, images, labels, property, SITE_URL } from "@/data/site";

export function getStaticPaths() {
  return getBlogPosts("ro").map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const path = `/blog/${post.slug}/`;
const translationPath = `/en/blog/${post.translationSlug}/`;
const l = labels.ro;
const locale = "ro" as const;
const showAirportTrainPlanner = post.slug === "cum-ajungi-de-la-otopeni-la-piata-muncii";
const cardVisual = getBlogCardVisual(post);
const cardImageUrl = `${SITE_URL}/images/${cardVisual.base}.webp`;

function cardLabel(index: number) {
  return String(index + 1).padStart(2, "0");
}

const galleryVideos = post.sections.flatMap((section) => [
  ...(section.video ? [section.video] : []),
  ...(section.videoGallery ?? [])
]);
const galleryImages = post.sections.flatMap((section) => section.imageGallery ?? []);
const inlineImages = post.sections.flatMap((section) =>
  section.image
    ? [
        {
          key: section.image,
          caption: { ro: section.imageCaption ?? "", en: section.imageCaption ?? "" }
        }
      ]
    : []
);
const schemaImages = [...galleryImages, ...inlineImages];

const videoSchemas = galleryVideos.map((video, idx) => ({
  "@type": "VideoObject",
  "@id": `${absoluteUrl(path)}#video-${idx}`,
  name: video.name[locale],
  description: video.description[locale],
  uploadDate: video.uploadDate,
  duration: `PT${video.durationSeconds}S`,
  thumbnailUrl: `${SITE_URL}${video.poster}`,
  contentUrl: `${SITE_URL}/video/${video.base}.mp4`,
  width: video.width,
  height: video.height,
  inLanguage: locale,
  isFamilyFriendly: true,
  ...(video.contentLocation
    ? {
        contentLocation: {
          "@type": "Place",
          name: video.contentLocation.name,
          ...(video.contentLocation.address ? { address: video.contentLocation.address } : {}),
          ...(video.contentLocation.lat != null && video.contentLocation.lon != null
            ? {
                geo: {
                  "@type": "GeoCoordinates",
                  latitude: video.contentLocation.lat,
                  longitude: video.contentLocation.lon
                }
              }
            : {})
        }
      }
    : {})
}));

const imageSchemas = schemaImages
  .map((item, idx) => {
    const meta = images[item.key as keyof typeof images];
    if (!meta) return null;
    const caption = item.caption[locale] || meta.alt[locale];
    return {
      "@type": "ImageObject",
      "@id": `${absoluteUrl(path)}#image-${idx}`,
      contentUrl: `${SITE_URL}${meta.webp}`,
      thumbnailUrl: `${SITE_URL}/images/${meta.base}-480.webp`,
      caption,
      description: meta.alt[locale],
      width: meta.width,
      height: meta.height,
      inLanguage: locale,
      representativeOfPage: false
    };
  })
  .filter((item): item is NonNullable<typeof item> => item !== null);
const primaryImageSchema = {
  "@type": "ImageObject",
  "@id": `${absoluteUrl(path)}#primaryimage`,
  contentUrl: cardImageUrl,
  thumbnailUrl: `${SITE_URL}/images/${cardVisual.base}-480.webp`,
  caption: post.title,
  description: cardVisual.alt[locale],
  width: BLOG_CARD_IMAGE_WIDTH,
  height: BLOG_CARD_IMAGE_HEIGHT,
  inLanguage: locale,
  representativeOfPage: true
};
const allImageSchemas = [primaryImageSchema, ...imageSchemas];

const howToSchema = post.howTo
  ? {
      "@type": "HowTo",
      "@id": `${absoluteUrl(path)}#howto`,
      name: post.howTo.name,
      description: post.howTo.description,
      ...(post.howTo.totalTime ? { totalTime: post.howTo.totalTime } : {}),
      step: post.howTo.steps.map((step, idx) => ({
        "@type": "HowToStep",
        position: idx + 1,
        name: step.name,
        text: step.text
      }))
    }
  : null;

const schema = [
  {
    "@type": "BlogPosting",
    headline: post.title,
    description: post.description,
    datePublished: post.date,
    dateModified: post.date,
    inLanguage: "ro",
    author: { "@type": "Organization", name: property.fullName },
    publisher: { "@type": "Organization", name: property.fullName },
    about: { "@id": `${SITE_URL}/#lodging` },
    keywords: post.keyword,
    mainEntityOfPage: absoluteUrl(path),
    image: allImageSchemas.map((item) => item.contentUrl),
    ...(videoSchemas.length ? { video: videoSchemas.map((item) => ({ "@id": item["@id"] })) } : {}),
    ...(howToSchema ? { mainEntity: { "@id": howToSchema["@id"] } } : {})
  },
  {
    "@type": "BreadcrumbList",
    "@id": `${absoluteUrl(path)}#breadcrumb`,
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Acasă", item: absoluteUrl("/") },
      { "@type": "ListItem", position: 2, name: "Blog", item: absoluteUrl("/blog/") },
      { "@type": "ListItem", position: 3, name: post.title, item: absoluteUrl(path) }
    ]
  },
  ...(howToSchema ? [howToSchema] : []),
  {
    "@type": "FAQPage",
    mainEntity: post.faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a }
    }))
  },
  ...videoSchemas,
  ...allImageSchemas
];
---

<BaseLayout locale="ro" path={path} translationPath={translationPath} title={`${post.title} - Serene Studio`} description={post.description} keyword={post.keyword} schema={schema} ogImage={`/images/${cardVisual.base}.webp`}>
  <article class="band">
    <div class="container article">
      <p class="article-meta">Actualizat: {post.date}</p>
      <h1>{post.title}</h1>
      <p class="hero-lead">{post.intro}</p>
      <div class="article-cta">
        <p>Pentru prețuri și disponibilitate, folosește butonul Rezervă online.</p>
        <BookingCta locale="ro" referer={`${post.ctaReferer}_top`} label={l.checkAvailability} />
      </div>
      {showAirportTrainPlanner && <AirportTrainPlanner locale="ro" />}
      <div class="article-content">
        {post.sections.map((section, index) => (
          <>
            <h2>{section.title}</h2>
            {section.intro && <p>{section.intro}</p>}
            {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
            {section.bullets && (
              <ul class="check-list">
                {section.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
            {section.cards && (
              <div class="cards-grid">
                {section.cards.map((card, cardIndex) =>
                  card.href ? (
                    <a class="card card-link" href={card.href} rel={card.href.startsWith("http") ? "noopener" : undefined}>
                      <span class="card-number">{card.eyebrow ?? cardLabel(cardIndex)}</span>
                      <h3>{card.title}</h3>
                      <p>{card.text}</p>
                      <span class="card-cta" aria-hidden="true">
                        Vezi detalii
                        <svg viewBox="0 0 24 24" focusable="false"><path d="M5 12h14m0 0-6-6m6 6-6 6" /></svg>
                      </span>
                    </a>
                  ) : (
                    <article class="card">
                      <span class="card-number">{card.eyebrow ?? cardLabel(cardIndex)}</span>
                      <h3>{card.title}</h3>
                      <p>{card.text}</p>
                    </article>
                  )
                )}
              </div>
            )}
            {section.image && images[section.image as keyof typeof images] && (
              <figure class="article-figure">
                <ResponsiveImage image={section.image as never} locale={locale} />
                {section.imageCaption && <figcaption>{section.imageCaption}</figcaption>}
              </figure>
            )}
            {section.imageGallery && (
              <div class="gallery-grid article-gallery">
                {section.imageGallery.map((item) => {
                  const meta = images[item.key as keyof typeof images];
                  const orient = meta && meta.height > meta.width ? "portrait" : "landscape";
                  const captionText = item.caption[locale];
                  return (
                    <figure class="gallery-item" data-orient={orient}>
                      <button
                        type="button"
                        class="gallery-trigger"
                        data-lightbox-trigger
                        data-full={meta?.webp}
                        data-caption={captionText}
                        aria-label={`Deschide imaginea: ${captionText}`}
                      >
                        <ResponsiveImage image={item.key as never} locale={locale} />
                      </button>
                      <figcaption>{captionText}</figcaption>
                    </figure>
                  );
                })}
              </div>
            )}
            {section.video && <SectionVideo data={section.video} locale={locale} />}
            {section.videoGallery && (
              <div class="video-gallery">
                {section.videoGallery.map((video) => (
                  <SectionVideo data={video} locale={locale} />
                ))}
              </div>
            )}
            {section.table && (
              <div class="table-wrap">
                <table>
                  <thead><tr>{section.table.headers.map((header) => <th>{header}</th>)}</tr></thead>
                  <tbody>{section.table.rows.map((row) => <tr>{row.map((cell) => <td>{cell}</td>)}</tr>)}</tbody>
                </table>
              </div>
            )}
            {index === 1 && (
              <div class="article-cta">
                <p>Rezervările se fac online, în pagina noastră securizată.</p>
                <BookingCta locale="ro" referer={`${post.ctaReferer}_mid`} label="Rezervă online" />
              </div>
            )}
          </>
        ))}
        <h2>Întrebări frecvente</h2>
        <FAQ items={post.faq} />
        <div class="article-cta">
          <p>Vezi prețul pentru datele tale și finalizează rezervarea online.</p>
          <BookingCta locale="ro" referer={`${post.ctaReferer}_final`} label={l.checkAvailability} />
        </div>
      </div>
    </div>
  </article>
  {galleryImages.length > 0 && <Lightbox locale="ro" />}
</BaseLayout>
